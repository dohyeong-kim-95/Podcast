# Local development defaults.

# Backend base URL used for generated audio links and scheduler OIDC validation.
# Production example:
# CLOUD_RUN_URL=https://podcast-api-xxxxx-uc.a.run.app
CLOUD_RUN_URL=http://localhost:8080

# Allowed browser origins for the FastAPI CORS middleware.
# Production example:
# CORS_ORIGINS=https://podcast.bubblelab.dev
CORS_ORIGINS=http://localhost:3000

# Optional allowlist for user login. Empty means allow any authenticated user.
ALLOWED_EMAILS=user1@example.com,user2@example.com

# Supabase project configuration.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# Direct Postgres connection for application data.
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# Supabase Storage bucket names.
SUPABASE_STORAGE_BUCKET_SOURCES=sources
SUPABASE_STORAGE_BUCKET_PODCASTS=podcasts

# Cloud Scheduler OIDC verification.
SCHEDULER_SERVICE_ACCOUNT=scheduler-invoker@your-project.iam.gserviceaccount.com

# Fernet key used to encrypt NotebookLM storage_state in Postgres.
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
NB_COOKIE_ENCRYPTION_KEY=replace-with-fernet-key

# Browserless new-tab auth flow.
# {session_id} and {token} placeholders are required by the current code.
BROWSERLESS_TOKEN=replace-with-browserless-token
BROWSERLESS_CONNECT_URL_TEMPLATE=wss://production-sfo.browserless.io?token={token}&sessionId={session_id}
BROWSERLESS_VIEWER_URL_TEMPLATE=https://production-sfo.browserless.io/sessions/{session_id}?token={token}

# Optional tuning for the Browserless NotebookLM auth flow.
NB_AUTH_TARGET_URL=https://notebooklm.google.com
NB_AUTH_TIMEOUT_SECONDS=300

# Optional tuning for generation behavior.
AUDIO_TIMEOUT_SECONDS=1200
GENERATE_MAX_CONCURRENCY=4
NB_SESSION_EXPIRING_SOON_DAYS=7

# Standard Web Push VAPID configuration.
VAPID_PUBLIC_KEY=replace-with-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-vapid-private-key
VAPID_SUBJECT=mailto:admin@bubblelab.dev
