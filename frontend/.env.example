# Supabase project for frontend auth.
# Production project:
# NEXT_PUBLIC_SUPABASE_URL=https://ocjsumocbjrfxgavmjze.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://ocjsumocbjrfxgavmjze.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Public VAPID key used by the browser Push API subscription flow.
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=your-web-push-public-key

# Backend base URL used by the browser.
# Example:
# NEXT_PUBLIC_API_BASE_URL=https://your-cloud-run-service.run.app
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
