# Public browser host URL exposed to end users.
REAUTH_HOST_PUBLIC_BASE_URL=https://reauth.bubblelab.dev
REAUTH_PUBLIC_HOSTNAME=reauth.bubblelab.dev

# Shared API key used by the backend to create sessions on the miniPC.
REAUTH_HOST_API_KEY=replace-with-long-random-value

# Optional runtime tuning.
REAUTH_HOST_MAX_SESSIONS=1
REAUTH_HOST_DISPLAY_BASE=90
REAUTH_HOST_WATCH_POLL_SECONDS=2
REAUTH_HOST_SESSION_ROOT=/tmp/reauth-host
REAUTH_CHROMIUM_EXECUTABLE=/usr/bin/chromium
REAUTH_NOVNC_STATIC_DIR=/usr/share/novnc
